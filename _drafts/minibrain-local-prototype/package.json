{
  "name": "minibrain",
  "version": "0.1.0",
  "description": "Postgres-native personal knowledge brain with hybrid RAG search",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "minibrain": "dist/cli.js"
  },
  "exports": {
    ".": "./dist/index.js",
    "./engine": "./dist/engine/interface.js",
    "./types": "./dist/types/index.js"
  },
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsup",
    "build:watch": "tsup --watch",
    "test": "vitest",
    "test:unit": "vitest test/unit",
    "test:integration": "vitest test/integration",
    "test:e2e": "vitest test/e2e",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts"
  },
  "keywords": ["mcp", "knowledge-base", "vector-search", "rag", "postgres"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@electric-sql/pglite": "^0.4.4",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "postgres": "^3.4.0",
    "yaml": "^2.3.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^20.0.0",
    "tsx": "^4.7.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.3.0",
    "@vitest/coverage-v8": "^1.3.0"
  }
}
